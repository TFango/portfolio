---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span>{text}</span>

<style>
  span {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--color-text-body);
    border: 1px solid var(--color-text-muted);
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
    white-space: nowrap;
  }
</style>
