---
interface Props {
  variant: "primary" | "secondary";
  icon?: "arrow" | "download";
  href: string;
  text: string;
}

import ArrowIcon from "../icons/ArrowIcon.astro";
import DownloadIcon from "../icons/DownloadIcon.astro";

const { variant, icon, href, text } = Astro.props;
---

<a href={href} class={`button button--${variant}`}>
  {text}
  {icon === "arrow" && <ArrowIcon />}
  {icon === "download" && <DownloadIcon />}
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.3rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      opacity 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .button--primary {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }

  .button--primary:hover {
    opacity: 0.85;
  }

  .button--secondary {
    background-color: transparent;
    color: var(--color-text-heading);
    border: 1px solid var(--color-text-muted);
  }

  .button--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
