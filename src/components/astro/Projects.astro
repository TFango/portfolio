---
import { getCollection } from "astro:content";
import ProjectTiltCard from "../react/ProjectTiltCard.tsx";

const proyectos = await getCollection("projects");

const proyectoDestacado =
  proyectos.find((proyecto) => proyecto.data.featured) ?? proyectos[0];

const otrosProyectos = proyectos.filter(
  (proyecto) => proyecto.id !== proyectoDestacado.id,
);
---

<section id="projects">
  <div>
    <div>
      <h2>Proyectos</h2>
    </div>

    <div class="featured">
      <ProjectTiltCard
        client:visible
        featured
        slug={proyectoDestacado.id}
        imageSrc={proyectoDestacado.data.image?.src ?? ""}
        title={proyectoDestacado.data.title}
        description={proyectoDestacado.data.description}
      />
    </div>

    <div class="grid">
      {
        otrosProyectos.map((proyecto) => (
          <ProjectTiltCard
            client:visible
            slug={proyecto.id}
            imageSrc={proyecto.data.image?.src ?? ""}
            title={proyecto.data.title}
            description={proyecto.data.description}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    display: flex;
    justify-content: center;
    padding: 6rem 2rem;
  }

  section > div {
    width: 100%;
    max-width: 1280px;
  }

  section > div > div:first-child {
    margin-bottom: 2.5rem;
  }

  h2 {
    font-size: 2.25rem;
  }

  .featured {
    max-width: 60%;
    margin: 0 auto 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }
</style>
