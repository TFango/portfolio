---

<section id="contact">
  <div class="contact-layout">
    <div class="contact-intro">
      <h2>¿Hablamos?</h2>
      <p>
        Estoy abierto a prácticas, colaboraciones y oportunidades para construir
        aplicaciones completas, no dudes en contactarme.
      </p>
    </div>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      id="contact-form"
    >
      <input
        type="hidden"
        name="access_key"
        value="b308fecb-6208-4e8d-9eab-31eae5414b9e"
      />
      <input
        type="hidden"
        name="subject"
        value="Nuevo mensaje desde el portfolio"
      />
      <input type="checkbox" name="botcheck" style="display: none" />

      <div class="field">
        <input type="text" id="name" name="name" placeholder=" " required />
        <label for="name">Nombre</label>
      </div>

      <div class="field">
        <input type="email" id="email" name="email" placeholder=" " required />
        <label for="email">Email</label>
      </div>

      <div class="field">
        <textarea id="message" name="message" placeholder=" " required
        ></textarea>
        <label for="message">Mensaje</label>
      </div>

      <button type="submit">Enviar</button>

      <p id="form-status"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const status = document.getElementById("form-status") as HTMLParagraphElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    status.textContent = "Enviando...";
    status.className = "";

    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });

      const result = await response.json();

      if (result.success) {
        status.textContent = "¡Mensaje enviado! Te voy a responder pronto.";
        status.className = "form-status--success";
        form.reset();
      } else {
        status.textContent = "Algo salió mal. Probá de nuevo en un rato.";
        status.className = "form-status--error";
      }
    } catch {
      status.textContent =
        "No se pudo enviar. Revisá tu conexión e intentá de nuevo.";
      status.className = "form-status--error";
    }
  });
</script>

<style>
  section {
    display: flex;
    justify-content: center;
    padding: 6rem 2rem;
  }

  .contact-layout {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    width: 100%;
    max-width: 1280px;
  }

  .contact-intro {
    flex: 1;
    max-width: 380px;
  }

  .contact-intro h2 {
    font-size: 2.25rem;
    margin-bottom: 1.25rem;
  }

  .contact-intro p {
    font-family: var(--font-body);
    color: var(--color-text-body);
    line-height: 1.7;
  }

  form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 480px;
  }

  .field {
    position: relative;
  }

  .field input,
  .field textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-text-muted);
    padding: 0.6rem 0;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-heading);
    transition: border-color 0.2s ease;
  }

  .field textarea {
    resize: vertical;
    min-height: 4rem;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .field label {
    position: absolute;
    left: 0;
    top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    pointer-events: none;
    transition:
      top 0.2s ease,
      font-size 0.2s ease,
      color 0.2s ease;
  }

  .field:has(input:focus) label,
  .field:has(input:not(:placeholder-shown)) label,
  .field:has(textarea:focus) label,
  .field:has(textarea:not(:placeholder-shown)) label {
    top: -1rem;
    font-size: 0.75rem;
    color: var(--color-accent);
  }

  button[type="submit"] {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-accent);
    background-color: var(--color-accent);
    color: var(--color-bg);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  button[type="submit"]:hover {
    opacity: 0.85;
  }

  #form-status {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    min-height: 1.2em;
  }

  #form-status.form-status--success {
    color: var(--color-accent);
  }

  #form-status.form-status--error {
    color: var(--color-error);
  }

  @media (max-width: 800px) {
    .contact-layout {
      flex-direction: column;
      gap: 3rem;
    }

    .contact-intro {
      max-width: none;
    }
  }
</style>
