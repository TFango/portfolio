---
import Tag from "../ui/Tag.astro";

const categorias = [
  {
    titulo: "LANGUAGES",
    items: ["TYPESCRIPT", "JAVASCRIPT", "HTML", "CSS", "JAVA"],
  },
  {
    titulo: "FRAMEWORKS & LIBRARIES",
    items: [
      "REACT",
      "NEXT.JS",
      "NODE.JS",
      "EXPRESS",
      "ASTRO",
      "SPRINGBOOT",
      "ANGULAR",
    ],
  },
  {
    titulo: "DATABASE & ORMS",
    items: ["MYSQL", "SEQUELIZE", "FIREBASE", "DRIZZLE", "NEONDB", "ALGOLIA"],
  },
  {
    titulo: "TOOLS & PLATFORMS",
    items: ["GIT", "GITHUB", "VERCEL", "CANVA", "FIGMA", "JIRA", "RAILWAY"],
  },
  {
    titulo: "AUTHENTICATION",
    items: ["NEXT-AUTH", "FIREBASE AUTH", "JWT"],
  },
  {
    titulo: "OTHER",
    items: ["REST APIS", "RESPONSIVE DESIGN", "UX/UI", "SCRUM"],
  },
];
---

<section id="skills">
  <div>
    <div>
      <span>Todo mi kit</span>
      <h2>Tecnologias</h2>
    </div>

    <div>
      {
        categorias.map((c) => (
          <div>
            <h3>{c.titulo}</h3>
            <div>
              {c.items.map((item) => (
                <Tag text={item} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    display: flex;
    justify-content: center;
    padding: 6rem;
  }

  section > div {
    width: 100%;
    max-width: 1280px;
  }

  section > div > div:first-child {
    margin-bottom: 3.5rem;
  }

  section > div > div:first-child span {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  h2 {
    font-size: 2.25rem;
  }

  /* grid de categorías */
  section > div > div:last-child {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 3rem;
    row-gap: 3rem;
  }

  h3 {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 1.1rem;
  }

  /* contenedor de tags dentro de cada categoría */
  h3 + div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
</style>
